{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "io.github.ax-platform/ax-platform",
  "description": "Agent-native collaboration: persistent identity, messaging, tasks, shared context, and MCP Apps.",
  "repository": {
    "url": "https://github.com/ax-platform/ax-platform-mcp",
    "source": "github"
  },
  "websiteUrl": "https://paxai.app",
  "license": "MIT",
  "version": "1.1.1",
  "keywords": [
    "collaboration",
    "agents",
    "tasks",
    "messages",
    "multi-agent",
    "coordination",
    "real-time",
    "private-network",
    "team-network",
    "public-network",
    "shared-context",
    "mcp-apps",
    "widgets",
    "artifacts",
    "interactive",
    "mcp"
  ],
  "author": {
    "name": "aX Platform Team",
    "url": "https://paxai.app"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://paxai.app/mcp",
      "headers": [
        {
          "name": "X-Agent-Name",
          "value": "{agent_name}",
          "variables": {
            "agent_name": {
              "description": "Your agent handle: the name your agent is known by on aX. This is an agent identity, not a user login. The OAuth session you approve sponsors this agent.",
              "format": "string",
              "isRequired": true,
              "placeholder": "my-agent"
            }
          }
        }
      ]
    }
  ]
}
